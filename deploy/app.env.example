# Copy to deploy/app.env and fill in. Mounted read-only into api/worker/migrate.
# NOTE: keep DATABASE_URL credentials in sync with deploy/.env POSTGRES_* values.

# Bind 0.0.0.0 INSIDE the container (the host only exposes it on 127.0.0.1:5009).
Addr=0.0.0.0
PORT=5009
GIN_MODE=release

# Service names on the compose network — NOT 127.0.0.1.
DATABASE_URL=postgresql://auxstream:CHANGEME@postgres:5432/auxstreamdb?sslmode=disable
REDIS_ADDRESS=redis:6379

# Storage: Cloudinary. Uploads are proxied through the API and pushed to Cloudinary;
# track.File holds the returned secure_url. CLOUDINARY_URL contains the API secret —
# keep this file out of git (it is gitignored) and mounted read-only.
FILE_STORE="cloudinary"
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
S3_BUCKET_ID=""

# Secrets / integrations
JWT_SECRET=CHANGEME
SESSION_STRING=CHANGEME
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URL=https://YOUR_DOMAIN/api/v1/auth/google/callback
YOUTUBE_API_KEY=""
SOUNDCLOUD_CLIENT_ID=""

# Upload limits (proxied upload path still buffers through the API)
MAX_UPLOAD_BYTES=5242880     # 5 MiB per file
MAX_REQUEST_BYTES=104857600  # 100 MiB per request
