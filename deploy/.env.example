# Prebuilt image to RUN on the VPS (pushed by CI to GHCR). Leave this UNSET for local
# dev: `make docker-up` builds and tags `auxstream:local` (the compose default), so the
# IMAGE var is not needed locally. Set it only on the VPS so `compose pull` fetches the
# prebuilt image. (Note: a literal `<owner>` is an invalid image reference — replace it.)
# IMAGE=ghcr.io/your-org/auxstream:latest

# Interface to bind the api port (5009) on. 127.0.0.1 = loopback only (host nginx
# reaches it). Set 0.0.0.0 only to expose the API directly (not recommended).
HTTP_BIND=127.0.0.1

# Interface (web) container — nginx serving the SPA + proxying /api to the api service.
# WEB_BIND: interface to publish the web port on; host nginx proxies to it.
# WEB_PORT: host port for the SPA (container stays 8080). Change if 8080 is taken.
# WEB_IMAGE: leave UNSET for local (`make docker-up` builds `auxstream-interface:local`);
#   set to the GHCR image on the VPS so `compose pull` fetches it.
# VITE_BASE_URL: baked into the SPA at build time; /api/v1 = same-origin via the web nginx.
WEB_BIND=127.0.0.1
WEB_PORT=8090
# WEB_IMAGE=ghcr.io/your-org/auxstream-interface:latest
VITE_BASE_URL=/api/v1

# Postgres container credentials — MUST match DATABASE_URL in app.env.
POSTGRES_USER=auxstream
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=auxstreamdb
